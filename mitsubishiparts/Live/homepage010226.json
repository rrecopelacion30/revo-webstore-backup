                      "value": "<div id=\"main--slider\" class=\"owl-carousel owl-theme\">\n    <div class=\"main--slider-item\">\n        <div class=\"main--slider-bg\" style=\"background-image: url(https://rparts-sites.s3.amazonaws.com/728796ac19bf35d33cacea37986d2661/design/mitsu_oct_advantage.webp);\">\n        </div>\n        <div class=\"main--slider-wrapper\"> \n            <div class=\"main--slider-content\"> \n                <h2>Advantage Select: Smarter Parts, Greater Value</h2>\n                <p class=\"main--slider-text\">\n                    Mitsubishi Advantage Select parts deliver the quality and reliability you expect&mdash;at a price that keeps your vehicle on the road without breaking the bank.\n                </p>\n                <div class=\"main--slider-buttton\">\n                    <a href=\"https://parts.mitsubishicars.com/advantage-select\">Shop Advantage Select</a>\n                </div>\n            </div>\n        </div>\n    </div>\n    <div class=\"main--slider-item\">\n        <div class=\"main--slider-bg\" style=\"background-image: url(https://rparts-sites.s3.amazonaws.com/728796ac19bf35d33cacea37986d2661/design/mitsu_hp.webp); background-position: 50% 50%;\">\n        </div>\n        <div class=\"main--slider-wrapper\"> \n            <div class=\"main--slider-content\"> \n                <h2>Mitsubishi Genuine Parts & Accessories</h2>\n                <p class=\"main--slider-text\">Experience peace of mind with every genuine Mitsubishi Part & Accessory&nbsp;</p>\n                <div class=\"main--slider-buttton\">\n                    <a href=\"javascript:openVehiclePicker();\">Shop Now</a>\n                </div>\n            </div> \n        </div>\n    </div>\n</div>"
