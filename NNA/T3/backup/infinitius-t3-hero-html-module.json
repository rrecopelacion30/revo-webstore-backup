      "value": "<style>\n\t.themeBannerList .themeBannerListImage {\n\t\theight: 500px;\n\t\tbackground-size: cover;\n\t\tbackground-repeat: no-repeat;\n\t\tbackground-position: center center;\n\t}\n\n\t.themeBannerList .themeBannerListContent {\n\t\tposition: absolute;\n\t\tleft: 0;\n\t\tright: 0;\n\t\ttop: 0;\n\t\tbottom: 0;\n\t\tdisplay: flex;\n\t\talign-items: center;\n\t}\n\n\t.themeBannerList .themeBannerListContent::before {\n\t\tcontent: \"\";\n\t\tposition: absolute;\n\t\tleft: 0;\n\t\tright: 0;\n\t\tbottom: 0;\n\t\ttop: 0;\n\t\tbackground-color: rgba(0, 0, 0, 0.5);\n\t}\n\n\t.themeBannerList .slide-content {\n\t\tmax-width: 1250px;\n\t\twidth: 100%;\n\t\tmargin-left: auto;\n\t\tmargin-right: auto;\n\t\tpadding-left: 15px;\n\t\tpadding-right: 15px;\n\t\tposition: relative;\n\t}\n\n\t.themeBannerList .slide-box {\n\t\tmax-width: 480px;\n\t\twidth: 100%;\n\t\tposition: relative;\n\t}\n\n\t.themeBannerList .slide-content h1 {\n\t\tcolor: #fff;\n\t\tfont-family: var(--themeFontLight) !important;\n\t\tfont-size: 1.875rem;\n\t\tline-height: normal;\n\t\tmargin-bottom: 15px;\n\t}\n\n\t.themeBannerList .slide-content .themeHeroTooltipWrap {\n\t\tcolor: #fff;\n\t\tmargin-bottom: 40px;\n\t\tfont-size: 14px;\n\t}\n\n\t.themeBannerList .slide-content .themeHeroTooltipAnchor {\n\t\tcolor: #fff;\n\t}\n\n\t.themeBannerList .themeHeroButton {\n\t\tdisplay: inline-block;\n\t\tfont-size: 16px;\n\t\tpadding: 10px 15px;\n\t\tborder: 1px solid var(--themeButtonColor);\n\t\tbackground-color: var(--themeButtonColor);\n\t\tmax-width: 200px;\n\t\ttext-align: center;\n\t\tfont-weight: 300;\n\t\twidth: 100%;\n\t\tcolor: var(--themeColor) !important;\n\t\tfont-family: var(--themeFontLight);\n\t\ttransition: all .3s ease-in-out;\n\t\tmargin-bottom: 0;\n\t}\n\n\t.themeBannerList .themeHeroButton:hover,\n\t.themeBannerList .themeHeroButton:focus {\n\t\ttext-decoration: none;\n\t}\n\n\t.promo_bold {\n\t\tfont-family: var(--themeFontBold) !important;\n\t}\n\t.themeBannerList .owl-nav,\n\t.themeBannerList .owl-dots {\n\t\tdisplay: none;\n\t}\n</style>\n<div class=\"themeBannerWrapper\">\n\t<div id=\"themeBannerList\" class=\"themeBannerList owl-carousel owl-theme\">\n\t\t<div class=\"themeBannerListItem\">\n\t\t\t<div class=\"themeBannerListCard\">\n\t\t\t\t<div class=\"themeBannerListImage v-pc\"\n\t\t\t\t\tstyle=\"background-image: url(https://cdn.revolutionparts.io/018bef32206c9ce0d9b45d83ce293d5c/design/promo/inf_ship_mar_desktop_t3.webp);\">\n\t\t\t\t</div>\n\t\t\t\t<div class=\"themeBannerListImage v-sp\"\n\t\t\t\t\tstyle=\"background-image: url(https://cdn.revolutionparts.io/018bef32206c9ce0d9b45d83ce293d5c/design/promo/inf_ship_mar_mobile_all.webp);\">\n\t\t\t\t</div>\n\t\t\t\t<div class=\"themeBannerListContent\">\n\t\t\t\t\t<div class=\"slide-content\">\n\t\t\t\t\t\t<div class=\"slide-box\">\n\t\t\t\t\t\t\t<h1>Score up to $25 off Shipping on qualifying online orders</h1>\n\t\t\t\t\t\t\t<p class=\"themeHeroTooltipWrap\">\n\t\t\t\t\t\t\t\tInstantly save up to $25 on shipping when you spend $100 on qualifying orders placed here 3/2–3/16.\n\t\t\t\t\t\t\t\t<a href=\"#\" class=\"themeHeroTooltipAnchor\">[*]</a>\n\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t<p class=\"themeHeroTooltip\">\n\t\t\t\t\t\t\t\tNot all items sold here are shippable. <span style=\"font-family: var(--themeFontBold) !important;\">Promotion valid only on  orders here of shippable parts & accessories with a minimum subtotal of $100 and made from 3/2/26 through 3/16/26 fulfilled by a participating U.S. INFINITI Retailer. Offer code automatically applied at online checkout.\n\t\t\t\t\t\t\t\t</span> Promotion covers up to $25 of the total shipping fee; any remaining shipping fee balance is the sole responsibility of the customer. No cash value. Void where prohibited. Other restrictions may apply. Contact participating U.S. INFINITI Retailer for details.\n\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t<a class=\"themeHeroButton\" href=\"javascript:openVehiclePicker();\">Shop Now</a>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"themeBannerListItem\">\n\t\t\t<div class=\"themeBannerListCard\">\n\t\t\t\t<div class=\"themeBannerListImage v-pc\"\n\t\t\t\t\tstyle=\"background-image: url(https://cdn.revolutionparts.io/018bef32206c9ce0d9b45d83ce293d5c/design/promo/inf_acc_mar_desktop_t3d.webp);\">\n\t\t\t\t</div>\n\t\t\t\t<div class=\"themeBannerListImage v-sp\"\n\t\t\t\t\tstyle=\"background-image: url(https://cdn.revolutionparts.io/018bef32206c9ce0d9b45d83ce293d5c/design/promo/inf_acc_mar_mobile_t1d.webp);\">\n\t\t\t\t</div>\n\t\t\t\t<div class=\"themeBannerListContent\">\n\t\t\t\t\t<div class=\"slide-content\">\n\t\t\t\t\t\t<div class=\"slide-box\">\n\t\t\t\t\t\t\t<h1>Get Road-Trip Ready with up to 20% off Select Genuine INFINITI Accessories</h1>\n\t\t\t\t\t\t\t<p class=\"themeHeroTooltipWrap\">\n\t\t\t\t\t\t\t\tSave up to 20% on select Genuine INFINITI Accessories with code <span style=\"font-family: var(--themeFontBold) !important;\">ROADTRIP26</span> when you shop online here 3/2–3/31.\n\t\t\t\t\t\t\t\t<a href=\"#\" class=\"themeHeroTooltipAnchor\">[*]</a>\n\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t<p class=\"themeHeroTooltip\">\n\t\t\t\t\t\t\t\t<span style=\"font-family: var(--themeFontBold) !important;\">ELIGIBILITY REQUIREMENTS:  Offer valid only on Select Genuine INFINITI Accessories, excluding  Affiliated Yakima Accessories and all Merchandise.. Promotion valid on online purchase made from 3/2/2026 through 03/31/2026 and fulfilled by participating U.S. INFINITI Retailer. Must apply offer code ROADTRIP26 at time of online checkout. Max discount $500.\n\t\t\t\t\t\t\t\t</span> Installation, shipping, handling, and tax additional. No cash value. Void where prohibited. Other restrictions may apply. Contact participating U.S. INFINITI Retailer for details.\n\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t<a class=\"themeHeroButton\" href=\"javascript:openVehiclePicker();\">Shop Now</a>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>