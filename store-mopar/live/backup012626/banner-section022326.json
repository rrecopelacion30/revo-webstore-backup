                "html_content": {
                  "name": "Custom HTML Content",
                  "type": "html_content",
                  "default_value": "",
                  "value": "<div class=\"themeNewBannerWrapper\">\n    <div id=\"themeNewBannerSlider\" class=\"themeNewBannerSlider owl-carousel owl-theme\">\n        <div class=\"themeNewBannerSliderItem\">\n            <div class=\"themeNewBannerSliderBox\">\n                <a href=\"https://www.dcperformance.com/?mt1carousel\">\n                    <div class=\"themeNewBannerSliderBox\">\n                        <div class=\"themeNewBAnnerSliderContent\">\n                            <div class=\"themeNewBannerSliderContentBox\">\n                                <h4>The Direct Connection Story</h4>\n                                <p class=\"themeNewBannerSliderText\">\n                                    Created 40 year ago, Direct Connection was the answer for the high demand for Mopar<sub>®</sub> performance parts.\n                                </p>\n                                <p class=\"themeNewBannerSliderButton\">\n                                    SHOP NOW\n                                </p>\n                            </div>\n                        </div>\n                        <div class=\"themeNewBannerSliderImg\">\n                            <img src=\"https://rparts-sites.s3.amazonaws.com/21ebc25a592052689288153b3e3fb858/design/new-home/slider/MOPAR_Direct_Connection_Banner_new_.webp\" fetchpriority=\"high\" alt=\"The Direct Connection Story\">\n                        </div>\n                    </div>\n                </a>\n            </div>\n        </div>\n        <div class=\"themeNewBannerSliderItem\">\n            <div class=\"themeNewBannerSliderBox\">\n                <a href=\"interactive-garage?mt1carousel\">\n                    <div class=\"themeNewBannerSliderBox\">\n                        <div class=\"themeNewBAnnerSliderContent\">\n                            <div class=\"themeNewBannerSliderContentBox\">\n                                <h4>MOPAR<sub>®</sub> CUSTOMIZER IS HERE</h4>\n                               