                  "options": {
                    "html_content": {
                      "name": "Custom HTML Content",
                      "type": "html_content",
                      "default_value": "",
                      "value": "<div class=\"themeSliderBannerWrap\">\n\t<div class=\"themeSliderBannerList\">\n        <div class=\"themeSliderBannerListItem\">\n            <div class=\"themeSliderBannerCard\">\n                <div class=\"themeSliderBannerImg\" style=\"background-image: url(https://rparts-sites.s3.amazonaws.com/00d43a1703c9241dcca9da0d452449dc/design/promos/mar/mopar_marmad_ship2.webp);\"></div>\n                <div class=\"themeSliderBannerContainer\">\n                    <div class=\"themeSliderBannerBox\">\n                        <div class=\"themeSliderBannerContent\">\n                            <h3 class=\"themeSliderBannerTitle\">\n                                Upgrade your ride the Mopar® way\n                            </h3>\n                            <p class=\"themeSliderBannerDesc WithTooltipWrapper\">\n                                Upgrade you Jeep® or RAM Truck with authentic Mopar® and Jeep Performance Parts. Watch real installs from trusted off-road creators and learn how to upgrade your vehicle with confidence.\n                            </p>\n                            <div class=\"themeSliderBannerButton\">\n                                <a href=\"javascript:openVehiclePicker();\">Shop Parts</a>\n                                <a href=\"javascript:openVehiclePicker();\">Find My Vehicle</a>\n                                <a href=\"javascript:openVehiclePicker();\">Watch Install Videos</a>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>"
